{
  "title": "FeatureFlow — ML Feature Store",
  "uid": "featureflow-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Feature Request Latency (p50 / p99)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(feature_request_latency_ms_bucket[1m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.99, rate(feature_request_latency_ms_bucket[1m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Features Served per Second",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(features_served_total[1m])",
          "legendFormat": "{{ entity_type }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Redis Lookup Latency (p50 / p99)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(redis_lookup_latency_ms_bucket[1m]))",
          "legendFormat": "p50 {{ entity_type }}"
        },
        {
          "expr": "histogram_quantile(0.99, rate(redis_lookup_latency_ms_bucket[1m]))",
          "legendFormat": "p99 {{ entity_type }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Cache Miss Rate",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(cache_miss_total[1m])",
          "legendFormat": "{{ entity_type }} / {{ feature_name }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Active Connections",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "active_connections",
          "legendFormat": "connections"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Total Features Served (last 5m)",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "increase(features_served_total[5m])",
          "legendFormat": "features"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    }
  ]
}
